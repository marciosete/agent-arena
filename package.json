{
  "name": "agent-arena",
  "private": true,
  "version": "1.0.0",
  "description": "Agent Arena — Road to the Final. A World Cup sportsbook built live by one engineer and a fleet of Claude agents.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "contracts",
    "services/*",
    "apps/*",
    "bots",
    "sim"
  ],
  "scripts": {
    "dev": "concurrently -k -n punter,trader,pricing,betting,sim -c cyan,magenta,yellow,green,blue \"npm run dev -w apps/punter-web\" \"npm run dev -w apps/trader-ops\" \"npm run dev -w services/pricing\" \"npm run dev -w services/betting\" \"npm run dev -w sim\"",
    "dev:web": "npm run dev -w apps/punter-web",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:shell": "shellcheck scripts/*.sh",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css,html,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,css,html,yml,yaml}\"",
    "check:new-code-coverage": "./scripts/check-new-code-coverage.sh",
    "check:duplicates": "jscpd .",
    "check:staged-duplicates": "./scripts/check-staged-duplication.sh",
    "check:cyclic": "madge --circular --extensions ts,tsx contracts/src services apps/punter-web/src apps/trader-ops/src bots/src sim/src",
    "quality-gate": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run check:duplicates",
    "secrets:check": "gitleaks detect --source . --verbose",
    "secrets:protect": "gitleaks protect --staged --verbose",
    "audit:check": "npm audit --omit=dev --audit-level=high",
    "audit:ci": "./scripts/audit-ci.sh",
    "osv:scan": "osv-scanner -L package-lock.json --format table",
    "osv:scan:high": "./scripts/osv-ci.sh",
    "ticker": "./scripts/ticker.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ],
    "*.sh": [
      "shellcheck"
    ]
  },
  "overrides": {
    "eslint-plugin-sonarjs": {
      "minimatch": "^10.2.4"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.6",
    "madge": "^8.0.0",
    "prettier": "^3.6.2",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4"
  }
}
