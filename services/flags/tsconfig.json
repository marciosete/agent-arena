{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "verbatimModuleSyntax": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "noEmit": false,
    "declaration": false,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": "./"
  },
  "include": ["src", "vitest.setup.ts"]
}
