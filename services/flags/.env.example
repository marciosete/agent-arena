# Copy to .env and fill in before the event.
#
# Neon: database "flags" in the same project:
FLAGS_DATABASE_URL="postgresql://<user>:<password>@<endpoint>.neon.tech/flags?sslmode=require"

# Admin authority is identity-based: PUT /flags/:key is gated by AdminGuard from
# @arena/service-auth, which reads the `admin` claim on the session JWT. Admins
# are minted via the shared SESSION_SECRET (and betting's ADMIN_EMAILS allowlist)
# — there is no service-local admin key to configure here.
SESSION_SECRET="<shared-across-arena-services>"
