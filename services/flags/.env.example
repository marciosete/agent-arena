# Copy to .env and fill in before the event.
#
# Neon: database "flags" in the same project:
FLAGS_DATABASE_URL="postgresql://<user>:<password>@<endpoint>.neon.tech/flags?sslmode=require"

# Write-guard: when set, PUT /flags/:key requires a matching x-admin-key
# header. Reads stay public. Leave unset for open writes in local dev.
FLAGS_ADMIN_KEY="<generate-a-long-random-string>"
