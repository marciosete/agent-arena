# Copy to .env for reference. The simulator has no database (in-memory by design).
#
# Control-plane guard: when set on the deployed service, POST /reset, /play-next
# and /run require an x-admin-key header matching this value. Reads (/state,
# /health) stay public. Unset locally = open control plane (intended for dev).
SIMULATOR_ADMIN_KEY="<generate-a-long-random-string>"

# Shared JWT secret (@arena/service-auth): verifies inbound Bearer tokens and
# signs the simulator's own service tokens for pricing/betting calls. Must match
# the other services' SESSION_SECRET; unset locally = the shared dev fallback.
# SESSION_SECRET="<shared-session-secret>"

# Where the finale chain fans out. Unset locally = the @arena/contracts
# BASE_URLS localhost defaults; deploys point these at the live services.
# PRICING_URL="https://pricing.example.com"
# BETTING_URL="https://betting.example.com"

# Betting's own admin key — settlement moves money, so POST /settle requires it
# on top of the service JWT. Must match the betting service's BETTING_ADMIN_KEY;
# unset locally = header omitted (betting's dev control plane is open).
# BETTING_ADMIN_KEY="<betting-admin-key>"

# Optional: fix the RNG seed for a reproducible tournament (unset = different
# every run).
# SIM_SEED=20260703
