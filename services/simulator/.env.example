# Copy to .env for reference. The simulator has no database (in-memory by design).
#
# Control-plane guard: when set on the deployed service, POST /reset, /play-next
# and /run require an x-admin-key header matching this value (wrong/missing key
# = 403). Unset locally = open control plane (intended for dev).
SIMULATOR_ADMIN_KEY="<generate-a-long-random-string>"

# Outbound settlement pipeline (pricing /reprice, betting /settle).
# Base URLs resolve env-first, falling back to the contract's local defaults.
# PRICING_URL="http://localhost:4001"
# BETTING_URL="http://localhost:4002"
#
# Betting's own admin key — /settle moves money, so betting demands it on top
# of the service JWT. REQUIRED wherever betting enforces it; without it every
# settlement is rejected and bets never pay out.
# BETTING_ADMIN_KEY="<betting's admin key>"
#
# Optional: numeric seed making simulated results deterministic (replayable
# theatre). Unset = seeded off the clock.
# SIMULATOR_SEED="42"
