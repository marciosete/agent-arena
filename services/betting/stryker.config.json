{
  "$schema": "../../node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.spec.ts",
    "!src/**/*.test.ts",
    "!src/**/__tests__/**",
    "!src/index.ts",
    "!src/main.ts",
    "!src/**/*.module.ts",
    "!src/health/**",
    "!src/prisma/**"
  ],
  "reporters": ["html", "clear-text", "progress"],
  "thresholds": { "high": 90, "low": 80, "break": 80 }
}
