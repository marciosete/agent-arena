// Betting-core database schema.
// The models (Account, Bet, LedgerEntry, ...) are designed and migrated LIVE
// by the betting workstream — see docs/specs/betting.md.
//
// Workflow:
//   1. define models below
//   2. npx prisma migrate dev --name <migration-name>   (creates + applies migration)
//   3. npx prisma generate                               (refresh the typed client)

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("BETTING_DATABASE_URL")
}

// Punter/bot wallet. Humans authenticate passwordlessly by email + OTP and are
// find-or-created on first successful verify; bots are provisioned by the admin
// key and have no inbox (email = null).
model Account {
  id        String   @id @default(uuid())
  email     String?  @unique
  name      String
  balance   Float    @default(10000)
  isBot     Boolean  @default(false)
  createdAt DateTime @default(now())
}

// One-time login code. We store only the SHA-256 hash, never the code itself.
// A row is single-use (consumedAt) and short-lived (expiresAt); attempts caps
// brute force before expiry.
model Otp {
  id         String    @id @default(uuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
}

enum BetStatus {
  pending
  won
  lost
  void
}

// A placed bet with its price locked at placement time. The unique constraint
// on idempotencyKey is the idempotency mechanism — the database is the referee,
// not application code. marketName is denormalised from pricing at placement so
// the exposure report never needs a second cross-service call.
model Bet {
  id              String    @id @default(uuid())
  accountId       String
  marketId        String
  marketName      String
  selectionId     String
  stake           Float
  price           Float
  potentialReturn Float
  status          BetStatus @default(pending)
  placedAt        DateTime  @default(now())
  settledAt       DateTime?
  idempotencyKey  String    @unique

  @@index([accountId])
  @@index([marketId, status])
}

// Append-only audit trail of every wallet movement (bet debits, win credits).
// Rows are only ever inserted — never updated or deleted — so the ledger always
// reconciles: Σ delta per account == balance - OPENING_BALANCE.
model LedgerEntry {
  id           String   @id @default(uuid())
  accountId    String
  delta        Float
  balanceAfter Float
  reason       String
  refBetId     String?
  createdAt    DateTime @default(now())

  @@index([accountId])
}
