# Copy to .env and fill in before the event.
#
# Neon (recommended): create a project at https://neon.tech, database "betting",
# and paste the connection string:
# BETTING_DATABASE_URL="postgresql://<user>:<password>@<endpoint>.neon.tech/betting?sslmode=require"
#
# Local fallback (docker compose up -d from repo root):
BETTING_DATABASE_URL="postgresql://arena:arena@localhost:5432/betting"
