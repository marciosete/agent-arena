# Copy to .env and fill in before the event.
#
# Create a Neon project at https://neon.tech with a database "betting" and
# paste its connection string:
BETTING_DATABASE_URL="postgresql://<user>:<password>@<endpoint>.neon.tech/betting?sslmode=require"

# Secret used to sign session tokens (HMAC-SHA256), shared across Arena services
# via @arena/service-auth. Set a long random value in every deployed
# environment; a well-known dev default is used when unset.
SESSION_SECRET=

# Admin key gating bot provisioning (POST /accounts). Endpoints are open when unset (local dev).
BETTING_ADMIN_KEY=

# Resend API key for delivering OTP emails. When unset, codes are logged to the
# console instead (local dev) — no email is sent.
RESEND_API_KEY=

# From-address for OTP emails (defaults to onboarding@resend.dev when unset).
RESEND_FROM=
