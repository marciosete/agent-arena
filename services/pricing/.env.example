# Copy to .env and fill in before the event.
#
# Neon (recommended): create a project at https://neon.tech, database "pricing",
# and paste the connection string:
# PRICING_DATABASE_URL="postgresql://<user>:<password>@<endpoint>.neon.tech/pricing?sslmode=require"
#
# Local fallback (docker compose up -d from repo root):
PRICING_DATABASE_URL="postgresql://arena:arena@localhost:5432/pricing"
