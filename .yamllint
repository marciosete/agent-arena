# yamllint configuration — pragmatic profile for workflow/compose files
extends: default

ignore: |
  node_modules/
  dist/
  coverage/
  package-lock.json

rules:
  line-length:
    max: 140
    level: warning
  document-start: disable
  truthy:
    # GitHub Actions uses "on:" as a key
    allowed-values: ['true', 'false', 'on']
  comments:
    min-spaces-from-content: 1
  # Prettier owns formatting and writes flow mappings as "{ a: b }" (one inner
  # space). Allow that so yamllint and prettier don't fight over matrix entries.
  braces:
    max-spaces-inside: 1
