# Copy to .env and fill in before running the roster (`npm run dev -w bots`).
#
# Base URLs of the services the bots bet into. Default to the @arena/contracts
# BASE_URLS (localhost) when unset; point them at the Render services in prod.
PRICING_URL=
BETTING_URL=

# Secret used to sign session tokens (HMAC-SHA256), shared across Arena services
# via @arena/service-auth. Bots mint an admin service token off this value; its
# unforgeable `admin` claim is what unlocks bot provisioning (POST /accounts).
# Must match the value betting is keyed on; a well-known dev default (which
# betting rejects) is used when unset.
SESSION_SECRET=

# Pause between betting rounds, in milliseconds (defaults to 10000 when unset or
# non-positive).
BOTS_ROUND_INTERVAL_MS=
