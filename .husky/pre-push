# Pre-push: everything must be green before code reaches the remote.
# Full suite → typecheck → duplication → dependency audit → OSV scan.

echo "🧪 Running full test suite before push..."
echo ""
if ! npm test; then
  echo ""
  echo "❌ Tests failed! Fix them before pushing."
  echo "   Run: npm test"
  echo ""
  exit 1
fi

echo ""
echo "🔍 Typechecking all workspaces..."
if ! npm run typecheck; then
  echo ""
  echo "❌ Typecheck failed! Fix errors before pushing."
  echo ""
  exit 1
fi

echo ""
echo "🔍 Checking code duplication across the repo (<3%)..."
if ! npm run check:duplicates; then
  echo ""
  echo "❌ Duplication above threshold! Refactor before pushing."
  echo ""
  exit 1
fi

echo ""
echo "🔒 Dependency audit (blocking on high/critical)..."
if command -v jq >/dev/null 2>&1; then
  if ! npm run audit:ci; then
    echo ""
    echo "❌ High/critical vulnerabilities in dependencies! Fix before pushing."
    echo ""
    exit 1
  fi
else
  echo "⚠️  jq not installed — falling back to npm audit"
  npm run audit:check || exit 1
fi

echo ""
echo "🔒 Running OSV-Scanner vulnerability check..."
if command -v osv-scanner >/dev/null 2>&1; then
  if ./scripts/osv-ci.sh; then
    echo "✅ OSV-Scanner passed!"
  else
    echo ""
    echo "❌ HIGH/CRITICAL vulnerabilities found! Fix them before pushing."
    echo "   Run: npm run osv:scan:high"
    echo ""
    exit 1
  fi
else
  echo "⚠️  osv-scanner not installed — skipping. Install: brew install osv-scanner"
fi

echo ""
echo "✅ All checks passed! Ready to push."
