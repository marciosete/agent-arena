# Copy to .env (gitignored). Read automatically by scripts/sonar.sh.
# Use a GLOBAL analysis token so one token scans every project:
#   SonarQube → Administration → Security → Users → Tokens → type "Global Analysis Token"
SONAR_TOKEN=
# Optional — defaults to the local stack. Point at Render/CI when needed.
# SONAR_HOST_URL=http://localhost:9000
